# Path to the DuckDB CLI executable
DUCKDB_CLI_PATH=your-duckdb-cli-path

# OpenAI API key for testing purposes
OPENAI_API_KEY=your-openai-api-key

# Ollama API URL for testing purposes
OLLAMA_API_URL=your-ollama-api-url

# OpenAI-compatible API (e.g. llama.cpp) for integration tests
# Example: llama-server -m model.gguf --port 8080
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_COMPATIBLE_API_KEY=not-needed
OPENAI_COMPATIBLE_MODELS=your-model-alias,another-model-alias
